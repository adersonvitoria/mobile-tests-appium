{
  "name": "mobile-tests-appium",
  "version": "1.0.0",
  "description": "Automação de testes mobile com Appium + WebdriverIO + Allure Reports",
  "scripts": {
    "test:android": "wdio run wdio.conf.ts",
    "test:android:login": "wdio run wdio.conf.ts --spec tests/specs/login.spec.ts",
    "test:android:form": "wdio run wdio.conf.ts --spec tests/specs/form.spec.ts",
    "allure:generate": "allure generate allure-results -o allure-report --clean",
    "allure:open": "allure open allure-report",
    "allure:report": "npm run allure:generate && npm run allure:open",
    "clean": "rimraf allure-results allure-report",
    "download:app": "node scripts/download-app.js",
    "postinstall": "appium driver install uiautomator2 || true"
  },
  "keywords": [
    "appium",
    "mobile",
    "testing",
    "automation",
    "webdriverio",
    "allure"
  ],
  "author": "adersonvitoria",
  "license": "MIT",
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@wdio/allure-reporter": "^9.24.0",
    "@wdio/appium-service": "^9.24.0",
    "@wdio/cli": "^9.24.0",
    "@wdio/local-runner": "^9.24.0",
    "@wdio/mocha-framework": "^9.24.0",
    "@wdio/spec-reporter": "^9.24.0",
    "allure-commandline": "^2.37.0",
    "appium": "^3.2.0",
    "appium-uiautomator2-driver": "^7.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
